# Environment variables — copy to .env and fill in your values
# Never commit .env to git!

# ── Pipeline Mode ──────────────────────────────────────────────────────────
# "hybrid" = Claude + Kling AI (default), "legacy" = Gemini + Pexels
PIPELINE_MODE=hybrid

# ── Anthropic (Claude 3.5 Sonnet — script + Kling prompts) ────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Kling AI (AI video generation) ────────────────────────────────────────
KLING_API_KEY=your_kling_api_key_here

# ── Gemini AI (legacy pipeline + SFX tagging) ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── ElevenLabs (primary voice — per-niche voices) ─────────────────────────
# Edge TTS is used as free fallback — no API key needed for that.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Pexels (stock footage — legacy pipeline fallback) ─────────────────────
PEXELS_API_KEY=your_pexels_api_key_here

# ── YouTube (OAuth 2.0) ────────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
# Get by running: python scripts/get_youtube_token.py
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here

# ── TikTok (Content Posting API) ───────────────────────────────────────────
# Get from https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
# Get by running: python scripts/get_tiktok_token.py
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# ── Amazon/Audible Affiliate ───────────────────────────────────────────────
AMAZON_AFFILIATE_TAG=your_amazon_tag_here
AUDIBLE_AFFILIATE_TAG=your_audible_tag_here
